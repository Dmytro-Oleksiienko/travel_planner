# Application
APP_NAME=Travel Planner API
APP_VERSION=1.0.0
DEBUG=true

# Database (SQLite for local dev, PostgreSQL for Docker)
DATABASE_URL=sqlite:///./travel_planner.db
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/travel_planner

# Art Institute of Chicago API
ARTIC_API_BASE_URL=https://api.artic.edu/api/v1
ARTIC_API_TIMEOUT=10

# Cache
CACHE_TTL=300
CACHE_MAX_SIZE=100

# Pagination
DEFAULT_PAGE=1
DEFAULT_PER_PAGE=10
MAX_PER_PAGE=100

# Limits
MAX_PLACES_PER_PROJECT=10
